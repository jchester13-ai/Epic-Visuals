<!-- WORKFLOW 4 — Consent Workflow (Digital First)               -->
<!-- ════════════════════════════════════════════════════════════ -->
<div id="w4" class="page">
  <div class="guide-card">
    <div class="guide-header">
      <div class="guide-num">4</div>
      <div class="guide-header-text">
        <h2>Primary Consent Workflow — Digital First</h2>
        <div class="purpose">Always use the digital path inside the patient chart · Media Manager is for paper backup only</div>
      </div>
    </div>
    <div class="guide-body">

      <div class="two-col" style="margin-bottom:18px;">

        <div style="border:2px solid var(--teal);border-radius:10px;overflow:hidden;">
          <div style="background:var(--teal);padding:10px 14px;">
            <div style="font-size:9.5px;font-weight:700;color:rgba(255,255,255,.75);text-transform:uppercase;letter-spacing:.6px;">Primary Path — Always Use This</div>
            <div style="font-size:13px;font-weight:700;color:white;margin-top:2px;">Digital Consent (In Chart)</div>
          </div>
          <div style="padding:14px;background:var(--teal-lt);">
            <div class="flow">
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot teal" style="width:17px;height:17px;font-size:8px;">1</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:11px;">
                  <div class="step-title" style="font-size:12px;">Open Patient Chart</div>
                  <div class="step-desc">Navigate to any active patient encounter or chart.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot teal" style="width:17px;height:17px;font-size:8px;">2</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:11px;">
                  <div class="step-title" style="font-size:12px;">Click "More" → Consents</div>
                  <div class="step-desc">In the chart toolbar, click <span class="epic-btn gray" style="font-size:10px;">More ▾</span> and select <strong>Consents</strong>.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot teal" style="width:17px;height:17px;font-size:8px;">3</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:11px;">
                  <div class="step-title" style="font-size:12px;">Verify Existing Forms</div>
                  <div class="step-desc">Review status of all current forms: Signed, Pending, or Missing.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot teal" style="width:17px;height:17px;font-size:8px;">4</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:11px;">
                  <div class="step-title" style="font-size:12px;">Add Missing Forms</div>
                  <div class="step-desc">Click <span class="epic-btn success" style="font-size:10px;">＋ Add Form</span> (green "+" button). Search and select the needed form.</div>
                  <div class="fields" style="margin-top:5px;">
                    <span class="field teal">Treatment Terms</span>
                    <span class="field teal">HIPAA</span>
                    <span class="field teal">Care Everywhere</span>
                    <span class="field teal">42 CFR Part 2 ROI</span>
                  </div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot teal" style="width:17px;height:17px;font-size:8px;">5</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:11px;">
                  <div class="step-title" style="font-size:12px;">Client Signs via Signature Pad</div>
                  <div class="step-desc">Present the signature pad. Client signs digitally. Witness signature if required.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot green" style="width:17px;height:17px;font-size:8px;">✓</div><div class="step-line last"></div></div>
                <div class="step-content" style="padding-bottom:0;">
                  <div class="step-title" style="font-size:12px;">File &amp; Sign to Complete</div>
                  <div class="step-desc">Click <span class="epic-btn success" style="font-size:10px;">File &amp; Sign</span>. Form status updates to "Signed."</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div style="border:2px solid var(--border);border-radius:10px;overflow:hidden;opacity:.85;">
          <div style="background:#6B7280;padding:10px 14px;">
            <div style="font-size:9.5px;font-weight:700;color:rgba(255,255,255,.75);text-transform:uppercase;letter-spacing:.6px;">Secondary / Backup Only</div>
            <div style="font-size:13px;font-weight:700;color:white;margin-top:2px;">Media Manager (Paper Scanning)</div>
          </div>
          <div style="padding:14px;background:#F9FAFB;">
            <div class="callout warn" style="margin-bottom:10px;">
              <div class="callout-label">⚠ Use Only for Physical Paper</div>
              Media Manager is <strong>only</strong> for scanning paper forms that cannot be obtained digitally. Do not use as the default path.
            </div>
            <div class="flow">
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot" style="width:17px;height:17px;font-size:8px;background:#6B7280;">1</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:10px;">
                  <div class="step-title" style="font-size:12px;">Add New Media</div>
                  <div class="step-desc">Open Media Manager → <span class="epic-btn gray" style="font-size:10px;">+ Add New Media</span>.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot" style="width:17px;height:17px;font-size:8px;background:#6B7280;">2</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:10px;">
                  <div class="step-title" style="font-size:12px;">Select Document Type</div>
                  <div class="step-desc">Choose the correct document category (e.g., "Consent Form – Paper").</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot amber" style="width:17px;height:17px;font-size:8px;">!</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:10px;">
                  <div class="step-title" style="font-size:12px;">Select Encounter (Required)</div>
                  <div class="step-desc"><strong>Required linkage</strong> — document will not index without an encounter association.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot" style="width:17px;height:17px;font-size:8px;background:#6B7280;">3</div><div class="step-line"></div></div>
                <div class="step-content" style="padding-bottom:10px;">
                  <div class="step-title" style="font-size:12px;">Scan / Import → Index → Upload</div>
                  <div class="step-desc">Scan, complete indexing fields, click <span class="epic-btn gray" style="font-size:10px;">Upload</span>.</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="step-connector"><div class="step-dot" style="width:17px;height:17px;font-size:8px;background:#6B7280;">✓</div><div class="step-line last"></div></div>
                <div class="step-content" style="padding-bottom:0;">
                  <div class="step-title" style="font-size:12px;">Document Filed</div>
                  <div class="step-desc">Visible in Media Manager. Note: will <em>not</em> appear in BHS SnapShot consent status.</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <div class="footnote"><strong>42 CFR Part 2:</strong> SUD records require a signed ROI before disclosure to any external party — including other DPH programs. Standard HIPAA TPO exceptions do not apply. Never disclose without a valid ROI on file.</div>
    </div>
  </div>
</div>


